{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["node", "mocha"],
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "server/src/**/*.ts", "server/test/**/*.ts", "sdk/src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
