{
  "name": "aldor",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "anchor test",
    "phase3:test": "MOCK_PAYMENTS=true SERVER_BASE_URL=http://127.0.0.1:3002 npm run build && mocha -t 120000 dist/server/test/**/*.test.js",
    "server:start": "npm run build && node --env-file=server/.env dist/server/src/main.js",
    "agent:install": "npm --prefix agent install",
    "agent:check": "npm --prefix agent run check",
    "agent:start": "npm --prefix agent run build && node agent/dist/index.js",
    "frontend:install": "npm --prefix frontend install",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:start": "npm --prefix frontend run start"
  },
  "dependencies": {
    "@bonfida/spl-name-service": "^3.0.21",
    "@coral-xyz/anchor": "^0.32.1",
    "@qvac/sdk": "^0.10.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "@umbra-privacy/sdk": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "axios": "^1.15.2",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.3.0",
    "@types/node-fetch": "^2.6.13",
    "@types/supertest": "^6.0.3",
    "chai": "^5.2.1",
    "mocha": "^11.7.1",
    "supertest": "^7.1.1",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.8.3"
  }
}
