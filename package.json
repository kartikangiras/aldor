{
  "name": "aldor",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "anchor test",
    "phase3:test": "MOCK_PAYMENTS=true SERVER_BASE_URL=http://127.0.0.1:3000 npm run build && mocha -t 120000 dist/server/test/**/*.test.js",
    "server:start": "npm run build && node dist/server/src/main.js",
    "agent:install": "npm --prefix agent install",
    "agent:check": "npm --prefix agent run check",
    "agent:start": "npm --prefix agent run build && node agent/dist/index.js"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.15.2",
    "bs58": "^6.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "@qvac/sdk": "^0.1.0",
    "@qvac/llm-llamacpp": "^0.1.0",
    "@qvac/embed-llamacpp": "^0.1.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.3.0",
    "@types/morgan": "^1.9.9",
    "@types/supertest": "^6.0.3",
    "chai": "^5.2.1",
    "mocha": "^11.7.1",
    "supertest": "^7.1.1",
    "ts-mocha": "^11.1.0",
    "typescript": "^5.8.3"
  }
}
